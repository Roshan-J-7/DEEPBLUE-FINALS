# ─────────────────────────────────────────────
# AI Voice Agent — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Cerebras API (LLM) — Get key at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key

# Twilio (Phone calls) — Get credentials at https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Google Cloud (STT & TTS) — Get key at https://console.cloud.google.com/
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key
GOOGLE_CLOUD_PROJECT_ID=your_project_id

# Deepgram (Speech-to-Text) — Optional, not used in current flow
DEEPGRAM_API_KEY=your_deepgram_api_key

# ElevenLabs (Text-to-Speech) — Optional, not used in current flow
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Server Configuration
PORT=3000
HOST=0.0.0.0
NGROK_URL=https://your-subdomain.ngrok-free.dev

# AI Agent Configuration
AI_MODEL=llama3.1-8b
SYSTEM_PROMPT=You are a helpful AI assistant speaking on the phone. Keep responses concise and conversational.
